TELEGRAM_BOT_TOKEN=replace_with_your_bot_token

# Used by Docker Compose to create the local PostgreSQL service.
POSTGRES_USER=waterchugger
POSTGRES_PASSWORD=localpassword
POSTGRES_DB=waterchugger

# Docker Compose supplies DATABASE_URL to the bot automatically. Set this only
# when running against a different PostgreSQL instance.
# DATABASE_URL=postgresql+asyncpg://waterchugger:localpassword@localhost:5432/waterchugger

REMINDER_INTERVAL_MINUTES=60
WORKOUT_REMINDER_INTERVAL_MINUTES=15
SNOOZE_MINUTES=15
MAX_AWAKE_HOURS=18
IDLE_EXPIRY_HOURS=24
CLEANUP_INTERVAL_SECONDS=300
SCHEDULER_INTERVAL_SECONDS=15
LOG_LEVEL=INFO
